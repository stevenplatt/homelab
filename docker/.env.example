# copy to .env and edit. docker compose loads .env automatically.

# huggingface token (only needed if you pull gated models like google/gemma-3-*)
HF_TOKEN=

# default model name used by the agent-tools container when calling the API.
# this should match a model you have pulled into lemonade.
# Gemma 4 31B (dense) at 4-bit quantization — ~20GB VRAM, fits R9700/32GB
# with plenty of room for context. confirm exact catalog name with
# `./lemonade list` if needed.
LEMONADE_MODEL=Gemma-4-31B-it-GGUF

# disable open-webui login by default. set to True if you want auth.
WEBUI_AUTH=False
